{
  "name": "tower-defense-wasm",
  "version": "1.0.0",
  "description": "Tower Defense in C++/WebAssembly — playable in-browser or via Electron",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build-wasm": "wsl bash -c \"cd /mnt/d/Code/tower-defense-wasm && ./build.sh\"",
    "build-and-run": "npm run build-wasm && npm start",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.brattseva.tower-defense",
    "productName": "Tower Defense",
    "files": [
      "electron/**/*",
      "web/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^25.1.8"
  }
}
